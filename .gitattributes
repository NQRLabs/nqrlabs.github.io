# Enforce LF line endings for all text files
* text=auto eol=lf

# Binary files - no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.mp3 binary
*.wav binary
*.ogg binary
*.mp4 binary
*.webm binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
